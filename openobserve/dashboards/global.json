              "lat": 0,
              "lng": 0
            },
            "wrap_table_cells": true
          },
          "queryType": "sql",
          "queries": [
            {
              "query": "SELECT sum(coalesce(length(payload_command),0)+coalesce(length(payload_path),0)+coalesce(length(payload_user_agent),0)+coalesce(length(payload_username),0)+coalesce(length(payload_password),0)+coalesce(length(payload_session_fingerprint),0)+coalesce(length(src_ip),0)+coalesce(length(session_id),0)+240) / 1048576.0 as \"y_axis_1\" FROM \"honeypot_events\"",
              "vrlFunctionQuery": "",
              "customQuery": true,
              "fields": {
                "stream": "honeypot_events",
                "stream_type": "logs",
